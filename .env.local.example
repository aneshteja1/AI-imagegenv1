# ─── Application ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="FaceSwap AI Platform"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── FastAPI Backend ──────────────────────────────────────────────────────────
# Set this to your Python FastAPI server URL
# If blank, the app falls back to built-in mock API routes
FASTAPI_URL=""
NEXT_PUBLIC_FASTAPI_URL=""

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET="change-this-to-a-random-256-bit-secret-key-in-production"
JWT_EXPIRY="24h"
JWT_REFRESH_EXPIRY="7d"

# ─── Azure PostgreSQL ─────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@your-server.postgres.database.azure.com:5432/faceswap?sslmode=require"

# ─── Azure Blob Storage ───────────────────────────────────────────────────────
AZURE_STORAGE_ACCOUNT_NAME="yourstorageaccount"
AZURE_STORAGE_ACCOUNT_KEY="your-storage-account-key"
AZURE_STORAGE_CONTAINER="faceswap-files"
AZURE_STORAGE_CONNECTION_STRING="DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net"

# ─── Supabase (alternative to Azure storage) ──────────────────────────────────
# SUPABASE_URL="https://your-project.supabase.co"
# SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ─── Stripe Payments ─────────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ─── Redis (for rate limiting) ────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Email (for notifications) ────────────────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
EMAIL_FROM="noreply@yourdomain.com"

# ─── External AI APIs ─────────────────────────────────────────────────────────
# These are consumed by your FastAPI backend, not Next.js directly
# REPLICATE_API_TOKEN="r8_..."
# OPENAI_API_KEY="sk-..."
# STABILITY_API_KEY="sk-..."

# ─── Security ─────────────────────────────────────────────────────────────────
CSRF_SECRET="another-random-secret-for-csrf-protection"
NEXTAUTH_SECRET="yet-another-random-secret"
ALLOWED_ORIGINS="http://localhost:3000,https://yourdomain.com"
